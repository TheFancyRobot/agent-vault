{
  "name": "@fancyrobot/agent-vault",
  "version": "0.4.1",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "description": "Durable project memory for coding agents. Obsidian-compatible vault with MCP server, pi package, and workflow support for Claude Code, OpenCode, pi, and Codex.",
  "bin": {
    "agent-vault": "./dist/cli.mjs"
  },
  "files": [
    "dist/",
    "prompts/",
    "pi-package/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "context:report": "bun run scripts/context-report.ts",
    "e2e:local": "bun run scripts/e2e-local.ts",
    "e2e:home": "bun run scripts/e2e-home.ts",
    "e2e:uninstall": "bun run scripts/e2e-uninstall.ts",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@toon-format/toon": "^2.1.0",
    "js-yaml": "^4.1.0",
    "playwright": "^1.59.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "verdaccio": "^6.3.2",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "pi-package",
    "agent",
    "vault",
    "mcp",
    "obsidian",
    "claude-code",
    "opencode",
    "codex",
    "project-memory"
  ],
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    },
    "@mariozechner/pi-ai": {
      "optional": true
    }
  },
  "pi": {
    "extensions": [
      "./pi-package/extensions"
    ],
    "skills": [
      "./pi-package/skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "image": "https://raw.githubusercontent.com/fancyrobot/agent-vault/main/assets/preview.png"
  },
  "license": "MIT"
}
